# URL del gateway — el frontend solo habla con el gateway, nunca con los servicios directamente
# Desarrollo local (gateway con uvicorn):
VITE_API_URL=http://localhost:8000/api
# Docker Compose (gateway en contenedor):
# VITE_API_URL=http://localhost:8000/api   ← mismo valor, el gateway expone el puerto 8000 al host
